# Required: Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Required: set one browser-safe key.
# Prefer NEXT_PUBLIC_SUPABASE_ANON_KEY for standard Supabase projects.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is also supported by the app as an alternative.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required for demo auth seeding and server-side XP writes
SUPABASE_SERVICE_ROLE_KEY=
